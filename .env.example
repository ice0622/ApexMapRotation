# このファイルを .env にコピーしてローカル開発に使う。
# 本物の .env は .gitignore 済み。絶対にコミットしないこと。
#   cp .env.example .env

# Apex Legends Status API キー（https://apexlegendsapi.com で取得）。
# 未設定の場合は自動でモックモードになる。
APEX_API_KEY=

# Discord Webhook URL。
# 対象チャンネル → 連携 → Webhook → 新しいWebhook → URLをコピー。
# これ自体が認証情報（知っている人は誰でも投稿できる）。秘密として扱うこと。
DISCORD_WEBHOOK_URL=

# true にすると実APIを呼ばずダミーデータを使う。
USE_MOCK=false

# check（変化時のみ通知） / status（現在の状況＋残り時間を今すぐ通知）。
MODE=check

# 任意: モック時に特定のマップ名を強制する。
# MOCK_MAP=Storm Point
